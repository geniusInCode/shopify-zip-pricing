# Port the backend listens on
PORT=3000

# Shopify App Proxy shared secret (matches your app proxy config)
SHOPIFY_API_SECRET=test123

# Allowed shop domains for app proxy (comma separated, or * for dev)
ALLOWED_SHOPS=*

# Default fallback price when no rule matches (cents)
DEFAULT_PRICE_CENTS=149900

# Database file location
DATABASE_PATH=./data/pricing.db

# CORS origin (your Shopify store domain, or * for dev)
CORS_ORIGIN=*